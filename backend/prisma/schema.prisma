// Control de Asistencia — Municipalidad
// Documentación: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Area {
  id         Int          @id @default(autoincrement())
  nombre     String       @unique
  fiscales   Fiscal[]
  trabajadores Trabajador[]
  creadoEn   DateTime     @default(now())
}

model Fiscal {
  id         Int      @id @default(autoincrement())
  nombre     String
  usuario    String   @unique
  password   String
  areaId     Int
  area       Area     @relation(fields: [areaId], references: [id])
  activo     Boolean  @default(true)
  creadoEn   DateTime @default(now())
}

model Trabajador {
  id           Int                  @id @default(autoincrement())
  nombre       String
  apellido     String
  dni          String               @unique
  areaId       Int
  area         Area                 @relation(fields: [areaId], references: [id])
  activo       Boolean              @default(true)
  registros    RegistroAsistencia[]
  creadoEn     DateTime             @default(now())
}

model RegistroAsistencia {
  id           Int              @id @default(autoincrement())
  trabajadorId Int
  trabajador   Trabajador       @relation(fields: [trabajadorId], references: [id])
  fecha        DateTime         @db.Date
  estado       EstadoAsistencia
  observacion  String?          @db.VarChar(500)
  creadoEn     DateTime         @default(now())
  actualizadoEn DateTime        @updatedAt

  @@unique([trabajadorId, fecha])
}

enum EstadoAsistencia {
  PRESENTE
  AUSENTE
  DESCANSO_SEMANAL
  DESCANSO_MEDICO
  PATERNIDAD
  VACACIONES
}
